{
  "profile_name": "codex_windows_default",
  "description": "Example profile for controlling Codex Desktop on Windows.",
  "hotkeys": {
    "paste_dictation": "f9",
    "clipboard_dictation": "f8"
  },
  "gamepad": {
    "enabled": true,
    "index": 0,
    "buttons": {
      "a": {
        "button": 0,
        "action": "dictate_paste",
        "focus_before_action": {
          "target": "message_input",
          "strategy": "lower_center_click",
          "x_ratio": 0.5,
          "bottom_offset_pixels": 100,
          "move_caret_to_end": true
        }
      },
      "b": {
        "button": 1,
        "action": "backspace",
        "repeat": true,
        "cooldown_seconds": 0.1
      },
      "lb": { "button": 4, "action": "mouse_left_click" },
      "rb": { "button": 5, "action": "mouse_right_click" },
      "x": { "button": 2, "action": "dictate_clipboard" }
    },
    "axes": {
      "lt": {
        "axis": 4,
        "threshold": 0.5,
        "release_threshold": 0.2,
        "cooldown_seconds": 0.3,
        "action": "space"
      },
      "rt": {
        "axis": 5,
        "threshold": 0.5,
        "release_threshold": 0.2,
        "cooldown_seconds": 0.8,
        "action": "enter"
      },
      "left_stick_y": {
        "axis": 1,
        "threshold": 0.65,
        "release_threshold": 0.25,
        "cooldown_seconds": 0.45,
        "negative_action": "chat_previous",
        "positive_action": "chat_next"
      },
      "right_stick_x": {
        "axis": 2,
        "threshold": 0.55,
        "release_threshold": 0.2,
        "cooldown_seconds": 0.25,
        "negative_action": "focus_chat_list",
        "positive_action": "focus_message_pane"
      },
      "right_stick_y": {
        "axis": 3,
        "threshold": 0.55,
        "release_threshold": 0.2,
        "cooldown_seconds": 0.08,
        "repeat": true,
        "scale_cooldown_by_intensity": true,
        "negative_action": "scroll_up",
        "positive_action": "scroll_down"
      }
    },
    "hats": {
      "dpad": {
        "hat": 0,
        "cooldown_seconds": 0.08,
        "repeat": true,
        "up_action": "cursor_up",
        "down_action": "cursor_down",
        "left_action": "cursor_left",
        "right_action": "cursor_right"
      }
    }
  },
  "paste": {
    "method": "sendinput",
    "delay_seconds": 0.35
  }
}
