{
  "profile_name": "local_quality_default",
  "description": "Example local speech profile that prioritizes recognition quality over startup speed.",
  "backend": "faster-whisper",
  "model": "large-v3",
  "device": "cuda",
  "compute_type": "float16",
  "language": "auto",
  "initial_prompt": "Russian technical dictation for AI workspaces. Preserve terms such as Codex, ChatGPT, GitHub, PowerShell, faster-whisper, SendInput, Python, pytest, and Windows. Use natural Russian punctuation.",
  "hotwords": [
    "Codex",
    "ChatGPT",
    "GitHub",
    "PowerShell",
    "faster-whisper",
    "SendInput",
    "Python",
    "pytest",
    "Windows"
  ],
  "postprocess": {
    "mode": "polished",
    "provider": "local_rules",
    "allow_external_services": false
  },
  "quality_gate": {
    "review_long_text_chars": 240,
    "max_postprocess_change_ratio": 0.25,
    "min_transcription_confidence": 0.55,
    "medium_transcription_confidence": 0.75,
    "block_auto_send_on_review": true
  },
  "fallback": {
    "enabled": true,
    "device": "cpu",
    "compute_type": "int8"
  }
}
